{
  "name": "MealPlan",
  "type": "object",
  "properties": {
    "org_id": {
      "type": "string"
    },
    "home_id": {
      "type": "string"
    },
    "home_name": {
      "type": "string"
    },
    "week_start": {
      "type": "string",
      "format": "date"
    },
    "created_by": {
      "type": "string"
    },
    "created_by_name": {
      "type": "string"
    },
    "days": {
      "type": "object",
      "description": "Keyed by day name: monday, tuesday, etc.",
      "properties": {
        "monday": {
          "type": "object",
          "properties": {
            "breakfast": {
              "type": "string"
            },
            "lunch": {
              "type": "string"
            },
