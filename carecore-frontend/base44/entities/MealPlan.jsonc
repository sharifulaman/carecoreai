              "type": "string"
            },
            "snacks": {
              "type": "string"
            }
          }
        },
        "tuesday": {
          "type": "object",
          "properties": {
            "breakfast": {
              "type": "string"
            },
            "lunch": {
              "type": "string"
            },
            "dinner": {
              "type": "string"
            },
            "snacks": {
              "type": "string"
            }
          }
        },
        "wednesday": {
          "type": "object",
          "properties": {
            "breakfast": {
              "type": "string"
            },
